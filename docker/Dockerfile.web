# ─── Build stage ──────────────────────────────────────────────────────────────
FROM node:22-slim AS builder

RUN corepack enable && corepack prepare pnpm@10.13.1 --activate

WORKDIR /app

# Copy workspace config + lockfile first (layer caching)
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json .npmrc ./
COPY packages/shared/package.json packages/shared/package.json
COPY packages/web/package.json    packages/web/package.json

# Install all workspace deps
RUN pnpm install --frozen-lockfile

# Copy source
COPY tsconfig.base.json ./
COPY packages/shared/ packages/shared/
COPY packages/web/    packages/web/

# Build shared first (web depends on @aice/shared types)
RUN pnpm --filter @aice/shared build

# Build the web frontend
# VITE_API_URL is empty — frontend uses relative URLs, Nginx proxies /api/* to api:3001
ENV VITE_API_URL=""
RUN pnpm --filter @aice/web build

# ─── Production stage ────────────────────────────────────────────────────────
FROM nginx:alpine

# Copy built static files
COPY --from=builder /app/packages/web/dist/ /usr/share/nginx/html/

# Copy Nginx config
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
