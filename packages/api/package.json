{
  "name": "@aice/api",
  "version": "0.0.1",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.dev src/index.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env.prod dist/index.js",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "dotenv -e ../../.env.dev -- tsx ../../scripts/prod-guard.ts prisma db push --schema=prisma/schema.prisma",
    "db:push:prod": "dotenv -e ../../.env.prod -- tsx ../../scripts/prod-guard.ts prisma db push --schema=prisma/schema.prisma",
    "db:studio": "dotenv -e ../../.env.dev -- prisma studio --schema=prisma/schema.prisma",
    "db:studio:prod": "dotenv -e ../../.env.prod -- prisma studio --schema=prisma/schema.prisma",
    "db:migrate": "dotenv -e ../../.env.dev -- prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:prod": "dotenv -e ../../.env.prod -- prisma migrate deploy --schema=prisma/schema.prisma",
    "db:fresh": "dotenv -e ../../.env.dev -- tsx ../../scripts/prod-guard.ts prisma migrate reset --schema=prisma/schema.prisma",
    "test:analyze": "tsx --env-file=../../.env.dev src/lib/test-analyze.ts",
    "import:csv": "dotenv -e ../../.env.prod -- tsx src/scripts/import-csv.ts"
  },
  "dependencies": {
    "@aice/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.37.0",
    "@google/generative-ai": "^0.24.1",
    "openai": "^4.85.0",
    "@prisma/client": "^6.0.0",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "mysql2": "^3.12.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
